###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
MESSENGER_TRANSPORT_DSN=${REDIS_URL}/messages
# MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0

MAILER_DSN=null://null

REDIS_URL=redis://localhost:6379

###> deployment ###
# Deployment webhook URLs for staging and production environments
# These are used by the CI/CD pipeline to trigger deployments
DEPLOY_WEBHOOK_URL_STAGING=
DEPLOY_WEBHOOK_URL=
# Secret token for authenticating deployment requests
DEPLOY_TOKEN=
