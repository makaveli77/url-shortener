{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}
{% block header %}Create an account{% endblock %}

{% block body %}
<div class="flex min-h-full flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-gray-800 py-8 px-4 shadow sm:rounded-lg sm:px-10">
        {{ form_start(registrationForm, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}
            
            {% if form_errors(registrationForm) %}
                <div class="rounded-md bg-red-900 border border-red-700 p-4 mb-4">
                    <div class="flex">
                        <div class="ml-3 text-sm text-red-200">
                            {{ form_errors(registrationForm) }}
                        </div>
                    </div>
                </div>
            {% endif %}

            <div class="mb-4">
                {{ form_row(registrationForm.email) }}
            </div>

            <div class="mb-4">
                {{ form_row(registrationForm.plainPassword) }}
            </div>

            <div>
                <button type="submit" class="flex w-full justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
                    Register
                </button>
            </div>
            
            <div class="mt-4 text-center text-sm">
                Already have an account? <a href="{{ path('app_login') }}" class="text-indigo-400 hover:text-indigo-300">Log in here</a>
            </div>
            
        {{ form_end(registrationForm) }}
    </div>
  </div>
</div>
{% endblock %}