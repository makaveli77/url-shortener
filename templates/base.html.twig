<!DOCTYPE html>
<html lang="en" class="h-full bg-gray-900">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}URL Shortener{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🔗</text></svg>">
        
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap("app") }}{% endblock %}
        {% endblock %}
    </head>
    <body class="h-full text-gray-100">
        <div class="min-h-full">
            <nav class="bg-gray-800">
                <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
                    <div class="flex h-16 items-center justify-between">
                        <div class="flex items-center">
                            <div class="flex-shrink-0 text-white font-bold text-xl">
                                🔗 Shorty
                            </div>
                            <div class="hidden md:block">
                                <div class="ml-10 flex items-baseline space-x-4">
                                    {% if app.user %}
                                        <a href="{{ path("app_dashboard") }}" class="rounded-md bg-gray-900 px-3 py-2 text-sm font-medium text-white" aria-current="page">Dashboard</a>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        <div>
                            <div class="ml-4 flex items-center md:ml-6 space-x-4">
                                {% if app.user %}
                                    <span class="text-gray-300 text-sm">{{ app.user.email }}</span>
                                    <a href="{{ path("app_logout") }}" class="rounded-md bg-red-600 px-3 py-2 text-sm font-medium text-white hover:bg-red-500">Logout</a>
                                {% else %}
                                    <a href="{{ path("app_login") }}" class="text-gray-300 hover:bg-gray-700 hover:text-white rounded-md px-3 py-2 text-sm font-medium">Login</a>
                                    <a href="{{ path("app_register") }}" class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-medium text-white hover:bg-indigo-500">Register</a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </nav>

            <header class="bg-gray-800 shadow border-b border-gray-700">
                <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
                    <h1 class="text-3xl font-bold tracking-tight text-white">{% block header %}Dashboard{% endblock %}</h1>
                </div>
            </header>

            <main>
                <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
                    {% block body %}{% endblock %}
                </div>
            </main>
        </div>
    </body>
</html>
